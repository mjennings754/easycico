<h1>Organizations#show</h1>
<p>Find me in app/views/organizations/show.html.erb</p>
<p>[<%= @organization.name %>]</p>
<p>Add users</p>
<%= form_with model: [@organization, @user] do |form| %>
    <% if @user.errors.any? %>
  <ul>
  <% @user.errors.full_messages.each do |msg| %>
    <li><%= msg %></li>
  <% end %>
  </ul>
<% end %>
    <%= form.label :username %>
    <%= form.text_field :username %>
    <%= form.label :email %>
    <%= form.email_field :email %>
    <%= form.label :password %>
    <%= form.password_field :password %>
    <%= form.label :password_confirmation %>
    <%= form.password_field :password_confirmation %>
    <%= form.submit %>
<% end %>
<p>Current users</p>
<% @organization.users.each do |user| %>
    <%= user.username %> [ <%= user.created_at.localtime %> ]
<% end %>